<div class="" data-controller="dashboard">
  <div class="flex justify-between items-center mb-4 sm:mb-6">
    <%# Setup Wizard CTA — amber-emphasis onboarding entry point (design: V4_CTA) %>
    <%= link_to get_started_path, title: "Setup Wizard", class: "group inline-flex items-center gap-3 rounded-[10px] border border-primary/40 bg-primary/10 py-2 pl-[9px] pr-3.5 text-left transition-all duration-200 hover:-translate-y-px hover:border-primary/70 hover:bg-primary/20 hover:shadow-[0_6px_18px_rgba(0,0,0,0.28)]" do %>
      <span class="flex h-[34px] w-[34px] shrink-0 items-center justify-center rounded-lg bg-primary/15 text-primary transition-colors duration-150 group-hover:bg-primary/25">
        <span class="icon icon-sm icon-wand"></span>
      </span>
      <span class="flex flex-col gap-0.5 leading-tight">
        <span class="text-[13.5px] font-semibold text-contentPrimary">Setup Wizard</span>
        <span class="text-[11.5px] font-medium text-contentSecondary">Set up a target and scan</span>
      </span>
      <span class="icon icon-sm icon-chevron-right ml-1 text-contentTertiary transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-primary"></span>
    <% end %>
    <div class="flex items-center gap-3">
      <span class="text-white font-sans text-sm font-normal leading-5">TIMEFRAME</span>
      <%= render partial: "admin/dashboard/period_select", locals: {
        target: "globalPeriod",
        action: "changeGlobalPeriod",
        selected: "30"
      } %>
    </div>
  </div>

  <div class="grid gap-4">
    <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 auto-rows-fr">
      <%= render "admin/dashboard/total_probes_card" %>
      <%= render "admin/dashboard/scans_quota_card" %>
      <%= render "admin/dashboard/average_asr_card" %>
      <%= render "admin/dashboard/average_scan_time_card" %>
    </div>

    <div class="grid gap-4 grid-cols-1 lg:grid-cols-3">
      <%= render "admin/dashboard/last_five_scans_card" %>
      <%= render "admin/dashboard/vulnerable_targets_card" %>
      <%= render "admin/dashboard/detector_activity_card" %>
    </div>

    <div class="grid gap-4 grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
      <%= render "admin/dashboard/taxonomy_distribution_card" %>
      <%= render "admin/dashboard/probe_disclosure_card" %>
      <%= render "admin/dashboard/scans_targets_time_card" %>
    </div>
  </div>
</div>
